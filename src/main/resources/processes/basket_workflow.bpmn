<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_04aw640" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.48.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:process id="basket-intake-workflow" name="Basket Intake Workflow" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Donation Basket Received">
      <bpmn:outgoing>Flow_0ewjc6l</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0ewjc6l" sourceRef="StartEvent_1" targetRef="Activity_0jdx1d3" />
    <bpmn:exclusiveGateway id="Gateway_112d2pg" name="Is Bulk Donation?">
      <bpmn:incoming>Flow_155l0u7</bpmn:incoming>
      <bpmn:outgoing>Flow_156sdv9</bpmn:outgoing>
      <bpmn:outgoing>Flow_11tg062</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1l3x97x" sourceRef="Activity_0jdx1d3" targetRef="Activity_0piyz08" />
    <bpmn:sequenceFlow id="Flow_156sdv9" name="${itemQuantity &#62; 1000}" sourceRef="Gateway_112d2pg" targetRef="Activity_1fwk7bl" />
    <bpmn:userTask id="Activity_1fwk7bl" name="Verify Capacity">
      <bpmn:incoming>Flow_156sdv9</bpmn:incoming>
      <bpmn:outgoing>Flow_09t4rwp</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_12g7yxf" name="Sync Basket Payload (POST)">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8080/api/donations</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">JSON.stringify({
  "itemName": execution.getVariable("itemName"),
  "category": execution.getVariable("category"),
  "quantity": Number(execution.getVariable("itemQuantity")),
  "dateEntered": execution.getVariable("dateEntered"),
  "status": "PENDING"
});</camunda:script>
            </camunda:inputParameter>
            <camunda:outputParameter name="postResponse">
              <camunda:script scriptFormat="javascript">response;</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_09t4rwp</bpmn:incoming>
      <bpmn:incoming>Flow_11tg062</bpmn:incoming>
      <bpmn:outgoing>Flow_18z73dk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_100uhx4" name="Inventory Updated">
      <bpmn:incoming>Flow_09iifzq</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_18z73dk" sourceRef="Activity_12g7yxf" targetRef="Activity_1gtdpf5" />
    <bpmn:sequenceFlow id="Flow_09t4rwp" sourceRef="Activity_1fwk7bl" targetRef="Activity_12g7yxf" />
    <bpmn:sequenceFlow id="Flow_155l0u7" sourceRef="Activity_0piyz08" targetRef="Gateway_112d2pg" />
    <bpmn:sequenceFlow id="Flow_1jta5v9" sourceRef="Activity_1gtdpf5" targetRef="Activity_0d31xvk" />
    <bpmn:sequenceFlow id="Flow_09iifzq" sourceRef="Activity_0d31xvk" targetRef="Event_100uhx4" />
    <bpmn:sequenceFlow id="Flow_11tg062" name="${itemQuantity &#60;= 1000}" sourceRef="Gateway_112d2pg" targetRef="Activity_12g7yxf">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_1gtdpf5" name="Update Allocation Totals (PUT)">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8080/api/donations</camunda:inputParameter>
            <camunda:inputParameter name="method">PUT</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">
              <camunda:script scriptFormat="javascript">```javascript
JSON.stringify({
"status": "ALLOCATED"
});</camunda:script>
            </camunda:inputParameter>
            <camunda:outputParameter name="putResponse">
              <camunda:script scriptFormat="javascript">response;</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_18z73dk</bpmn:incoming>
      <bpmn:outgoing>Flow_1jta5v9</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0d31xvk" name="Purge Temporary Session Cache (DELETE)">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8080/api/donations</camunda:inputParameter>
            <camunda:inputParameter name="method">DELETE</camunda:inputParameter>
            <camunda:outputParameter name="deleteResponse">
              <camunda:script scriptFormat="javascript">response;</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jta5v9</bpmn:incoming>
      <bpmn:outgoing>Flow_09iifzq</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0piyz08" name="Fetch Inventory Metrics (GET)">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">http://localhost:8080/api/donations</camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
            <camunda:outputParameter name="inventoryDetails">
              <camunda:script scriptFormat="javascript">response;</camunda:script>
            </camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1l3x97x</bpmn:incoming>
      <bpmn:outgoing>Flow_155l0u7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_0jdx1d3" name="Register Basket Payload">
      <bpmn:incoming>Flow_0ewjc6l</bpmn:incoming>
      <bpmn:outgoing>Flow_1l3x97x</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
